  {/* Spotify embed — uncomment and replace ARTIST_ID when ready */}
  {/* To get it: go to your Spotify artist page → Share → Copy link → the ID is the part after /artist/ */}
  {/*
  <div class="spotify-embed">
    <iframe
      style="border-radius:12px"
      src="https://open.spotify.com/embed/artist/ARTIST_ID?utm_source=generator&theme=0"
      width="100%"
      height="152"
      frameBorder="0"
      allowfullscreen=""
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
    ></iframe>
  </div>
  */}

  {/* Email signup — uncomment and replace MAILCHIMP_FORM_ACTION_URL and b_MAILCHIMP_ID when ready */}
  {/*
  <div class="email-signup">
    <h2>stay in touch</h2>
    <form action="MAILCHIMP_FORM_ACTION_URL" method="post" target="_blank">
      <input type="email" name="EMAIL" placeholder="your email" required />
      <div style="position:absolute;left:-5000px" aria-hidden="true">
        <input type="text" name="b_MAILCHIMP_ID" tabindex="-1" value="" />
      </div>
      <button type="submit">subscribe</button>
    </form>
    <p class="email-note">no spam, just updates on new music and writings</p>
  </div>
  */}

  <footer class="site-footer">
    <a href="/privacy/">privacy</a>
  </footer>

</Base>
