---
import Base from '../layouts/Base.astro';
---
<Base>

  <h1>l e s h y</h1>

  <nav class="link-container">

    <div class="column">
      <h2>music</h2>
      <a class="bandcamp" href="https://madebyleshy.bandcamp.com/" target="_blank" rel="noopener noreferrer">bandcamp</a>
      <a class="spotify" href="#" target="_blank" rel="noopener noreferrer">spotify</a>
    </div>

    <div class="column">
      <h2>video</h2>
      <a class="youtube" href="https://www.youtube.com/@madebyleshy" target="_blank" rel="noopener noreferrer">youtube</a>
      <a class="twitch" href="#" target="_blank" rel="noopener noreferrer">twitch</a>
    </div>

    <div class="column">
      <h2>social</h2>
      <a class="instagram" href="https://instagram.com/madebyleshy" target="_blank" rel="noopener noreferrer">instagram</a>
      <a class="tiktok" href="https://tiktok.com/@madebyleshy" target="_blank" rel="noopener noreferrer">tiktok</a>
      <a class="x" href="https://x.com/madebyleshy" target="_blank" rel="noopener noreferrer">x</a>
    </div>

  </nav>

